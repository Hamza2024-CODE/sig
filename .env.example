# ══ الاتصال بقاعدة البيانات البعيدة HFSQL ════════════════════════════
HFSQL_DSN="Driver={HFSQL};Server Name=197.112.101.166;Server Port=4900;Database=sig;IntegrityCheck=0"
HFSQL_USERNAME="sig"
HFSQL_PASSWORD=

# ══ الجلسات والتحكم بالطابور ═══════════════════════════════════════
SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
QUEUE_DRIVER=database

# ══ أدوات التتبع والتوثيق ══════════════════════════════════════════
SENTRY_LARAVEL_DSN=null
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SAMPLE_RATE=0
L5_SWAGGER_GENERATE_ALWAYS=false

# ══ إعدادات المراقبة الفورية ونظام التنبيهات ═════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

                "tags": [
                    "Trainees"
                ],
                "summary": "جلب قائمة المتربصين مع الفلترة والبحث",
                "description": "GET /api/v1/stagiaires\n\nReturns a paginated list of trainees.\nUses Apprenant::forListing() which has optimized eager loading to avoid N+1 queries.\nCapped at 50 items per page for safety.",
                "operationId": "9b5c2dc21e5b5f4e463d2c412b956434",
                "parameters": [
                    {
                        "name": "valide",
                        "in": "query",
                        "description": "فلترة حسب النشاط (1 لـ نشط، 0 لـ غير نشط)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "enum": [
                                0,
                                1
                            ]
                        }
                    },
                    {
                        "name": "etablissement_id",
                        "in": "query",
                        "description": "معرف المؤسسة",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "specialite_id",
                        "in": "query",
                        "description": "معرف التخصص",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "sexe",
                        "in": "query",
                        "description": "الجنس (M أو F)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "M",
                                "F"
                            ]
                        }
                    },
                    {
                        "name": "q",
                        "in": "query",
                        "description": "بحث بالاسم أو اللقب أو رقم الملف",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "تم جلب قائمة المتربصين بنجاح"
                    },
                    "401": {
                        "description": "غير مصرح بالدخول"
                    }

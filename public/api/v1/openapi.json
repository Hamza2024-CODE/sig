              }
            }
          },
          "401": {
            "description": "توثيق خاطئ أو مفقود",
            "content": {
              "application/json": {
                "example": {
                  "status": "error",
                  "code": 401,
                  "message": "Invalid or expired API authorization."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "أرسل الرمز المستخرج من /api/v1/auth/token في رأس الطلب بصيغة: Authorization: Bearer <jwt_token>"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "أرسل مفتاح الـ API المباشر في رأس الطلب بصيغة: X-API-Key: sgfep_ext_..."
      }
    }
  }
}

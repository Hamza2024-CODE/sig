{
    "name": "mfep/sgfep",
    "description": "Syst\u00e8me de Gestion de la Formation et de l'Enseignement Professionnels",
    "type": "project",
    "require": {
        "php": ">=8.0.2",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^1.29",
        "chillerlan/php-qrcode": "^5.0",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10",
        "intervention/image": "^2.7",
        "laravel/framework": "^9.0",
        "sentry/sentry-laravel": "^4.25",
        "darkaonline/l5-swagger": "^8.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6"
    }
}
